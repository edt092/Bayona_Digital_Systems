---
import { services } from '@/data/services';
---

<section id="servicios" class="section bg-[#080808]" aria-label="Servicios">
  <div class="max-w-7xl mx-auto px-6">

    <!-- Header -->
    <div class="text-center max-w-2xl mx-auto mb-16 reveal">
      <div class="section-badge justify-center mb-4">
        <span class="badge badge-primary">Servicios</span>
      </div>
      <h2 class="text-3xl md:text-4xl font-bold mb-4">
        Todo lo que necesita tu negocio para
        <span class="neon-yellow"> crecer online</span>
      </h2>
      <p class="text-[var(--color-muted)] text-lg">
        No trabajo con paquetes genéricos. Cada estrategia se diseña según tus objetivos específicos y tu mercado.
      </p>
    </div>

    <!-- Service cards -->
    <div class="grid md:grid-cols-3 gap-5">
      {services.map((service, i) => (
        <article
          class={`card p-8 flex flex-col reveal delay-${(i + 1) * 100}`}
          aria-label={`Servicio: ${service.title}`}
        >
          <!-- Icon -->
          <div class="w-11 h-11 rounded-xl bg-[#1E1E1E] border border-[#282828] flex items-center justify-center mb-6 text-[#909090]">
            <div class="w-5 h-5" set:html={service.icon}></div>
          </div>

          <!-- Problem -->
          <div class="mb-4">
            <span class="text-xs font-medium text-[#4A4A4A] italic">
              "{service.problem}"
            </span>
          </div>

          <!-- Title & description -->
          <h3 class="text-lg font-semibold mb-3 text-[var(--color-ink)]">{service.title}</h3>
          <p class="text-[var(--color-muted)] text-sm leading-relaxed mb-6 flex-1">
            {service.description}
          </p>

          <!-- Benefits -->
          <ul class="space-y-2 mb-8">
            {service.benefits.map(benefit => (
              <li class="flex items-start gap-2.5 text-sm">
                <svg class="w-3.5 h-3.5 mt-0.5 flex-shrink-0 text-[#606060]" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
                  <polyline points="20 6 9 17 4 12"/>
                </svg>
                <span class="text-[var(--color-ink)] text-sm">{benefit}</span>
              </li>
            ))}
          </ul>

          <!-- CTA -->
          <a
            href="#contacto"
            class="btn btn-outline text-sm w-full justify-center group"
          >
            {service.cta}
            <svg class="w-3.5 h-3.5 transition-transform group-hover:translate-x-1" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <path d="M5 12h14M12 5l7 7-7 7"/>
            </svg>
          </a>
        </article>
      ))}
    </div>

  </div>
</section>

<style>
  .neon-yellow {
    color: #FFE135;
    text-shadow:
      0 0 8px  rgba(255, 220, 0, 0.9),
      0 0 20px rgba(255, 200, 0, 0.7),
      0 0 45px rgba(255, 180, 0, 0.5),
      0 0 80px rgba(255, 160, 0, 0.25);
  }
</style>
