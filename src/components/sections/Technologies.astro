---

<section id="tecnologias" class="section bg-[#080808]" aria-label="Tecnologías">
  <div class="max-w-7xl mx-auto px-6">

    <!-- Header -->
    <div class="text-center max-w-xl mx-auto mb-14 reveal">
      <div class="section-badge justify-center mb-4">
        <span class="badge badge-primary">Stack técnico</span>
      </div>
      <h2 class="text-3xl md:text-4xl font-bold mb-4">
        Herramientas de
        <span class="gradient-text"> nivel profesional</span>
      </h2>
      <p class="text-[var(--color-muted)]">
        Trabajo con las tecnologías más modernas para garantizar performance, mantenibilidad y resultados.
      </p>
    </div>

    <!-- Tech groups -->
    <div class="space-y-12">
      {techGroups.map((group, gi) => (
        <div class={`reveal delay-${gi * 200}`}>
          <div class="flex items-center gap-3 mb-6">
            <span class="text-[10px] font-bold text-[#4A4A4A] uppercase tracking-[0.15em]">{group.label}</span>
            <div class="flex-1 h-px bg-[#1E1E1E]"></div>
          </div>

          <div class="grid grid-cols-3 sm:grid-cols-5 gap-4">
            {group.items.map((tech) => (
              <div class="card p-4 flex flex-col items-center gap-2.5 cursor-default group">
                <div
                  class="w-10 h-10 rounded-xl flex items-center justify-center opacity-60 group-hover:opacity-90 transition-opacity"
                  style={`background: ${tech.color}15; color: ${tech.color};`}
                >
                  <div class="w-5 h-5" set:html={tech.icon}></div>
                </div>
                <span class="text-xs font-medium text-[#505050] text-center leading-tight group-hover:text-[#ECECEC] transition-colors">{tech.name}</span>
              </div>
            ))}
          </div>
        </div>
      ))}
    </div>

  </div>
</section>
