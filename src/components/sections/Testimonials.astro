---
import { testimonials } from '@/data/testimonials';
---

<section id="testimonios" class="section bg-white" aria-label="Testimonios">
  <div class="max-w-7xl mx-auto px-6">

    <!-- Header -->
    <div class="text-center max-w-2xl mx-auto mb-14 reveal">
      <div class="section-badge justify-center mb-4">
        <span class="badge badge-accent">Testimonios</span>
      </div>
      <h2 class="text-3xl md:text-4xl font-black mb-4">
        Lo que dicen quienes ya
        <span class="gradient-text"> confían en nosotros</span>
      </h2>
      <p class="text-[var(--color-muted)]">
        Resultados reales de clientes reales. Sin testimonios inventados.
      </p>
    </div>

    <!-- Testimonials grid -->
    <div class="grid md:grid-cols-2 gap-6">
      {testimonials.map((testimonial, i) => (
        <article
          class={`card p-8 relative reveal delay-${(i % 2 === 0 ? i + 1 : i) * 100}`}
          aria-label={`Testimonio de ${testimonial.name}`}
        >
          <!-- Quote mark -->
          <div
            class="absolute top-6 right-6 text-6xl font-serif text-[var(--color-border)] leading-none select-none"
            aria-hidden="true"
          >"</div>

          <!-- Stars -->
          <div class="flex items-center gap-1 mb-4" aria-label={`${testimonial.rating} de 5 estrellas`}>
            {Array.from({ length: testimonial.rating }).map(() => (
              <svg class="w-4 h-4 text-yellow-400" viewBox="0 0 24 24" fill="currentColor">
                <path d="m12 2 3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"/>
              </svg>
            ))}
          </div>

          <!-- Result badge -->
          <div class="mb-4">
            <span class="badge badge-accent text-[10px]">
              <svg class="w-3 h-3" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
                <polyline points="22 7 13.5 15.5 8.5 10.5 2 17"/>
              </svg>
              {testimonial.result}
            </span>
          </div>

          <!-- Quote -->
          <blockquote class="text-[var(--color-muted)] leading-relaxed mb-6 text-sm italic relative z-10">
            "{testimonial.quote}"
          </blockquote>

          <!-- Author -->
          <div class="flex items-center gap-3 pt-4 border-t border-[var(--color-border)]">
            <!-- Avatar -->
            {testimonial.avatar ? (
              <img
                src={testimonial.avatar}
                alt={`Foto de ${testimonial.name}`}
                class="w-10 h-10 rounded-full object-cover flex-shrink-0 border-2 border-[var(--color-border)]"
                loading="lazy"
              />
            ) : (
              <div
                class="w-10 h-10 rounded-full flex items-center justify-center text-white font-bold text-sm flex-shrink-0 font-display"
                style="background: linear-gradient(135deg, var(--color-primary), var(--color-secondary));"
              >
                {testimonial.name.split(' ').map(n => n[0]).join('').slice(0, 2)}
              </div>
            )}
            <div>
              <div class="font-semibold text-[var(--color-ink)] text-sm">{testimonial.name}</div>
              <div class="text-xs text-[var(--color-muted)]">{testimonial.role} · {testimonial.company}</div>
            </div>
          </div>
        </article>
      ))}
    </div>

  </div>
</section>
