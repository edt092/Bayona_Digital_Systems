---
---

<section id="contacto" class="section relative overflow-hidden" aria-label="Contacto">
  <!-- Background -->
  <div
    class="absolute inset-0"
    style="background: linear-gradient(135deg, var(--color-primary) 0%, var(--color-secondary) 60%, var(--color-accent-dark) 100%);"
  ></div>
  <div class="absolute inset-0 bg-grid opacity-10"></div>

  <!-- Glow effects -->
  <div
    class="absolute top-1/2 left-1/4 -translate-y-1/2 w-96 h-96 rounded-full opacity-20"
    style="background: radial-gradient(circle, var(--color-accent) 0%, transparent 70%);"
    aria-hidden="true"
  ></div>

  <div class="relative max-w-4xl mx-auto px-6 text-center text-white">

    <!-- Badge -->
    <div class="section-badge justify-center mb-6 reveal">
      <span class="inline-flex items-center gap-2 text-xs font-bold px-3 py-1.5 rounded-full border border-white/20 bg-white/10 text-white/90 uppercase tracking-wider">
        <span class="w-1.5 h-1.5 rounded-full bg-[var(--color-accent-light)]" style="animation: pulse-dot 1.5s ease-in-out infinite;"></span>
        Comencemos
      </span>
    </div>

    <h2 class="text-4xl md:text-5xl lg:text-6xl font-black leading-tight mb-6 reveal delay-100">
      ¿Listo para hacer crecer<br/>
      <span class="text-[var(--color-accent-light)]">tu negocio?</span>
    </h2>

    <p class="text-xl text-white/75 leading-relaxed mb-10 max-w-2xl mx-auto reveal delay-200">
      Agenda una llamada de 30 minutos sin costo. Analizamos tu situación actual y diseñamos juntos el plan de acción.
    </p>

    <!-- CTAs -->
    <div class="flex flex-col sm:flex-row gap-4 justify-center mb-12 reveal delay-300">
      <a
        href="#"
        data-booking-open
        class="btn text-base py-4 px-8 bg-white text-[var(--color-primary)] hover:bg-white/95 shadow-xl hover:shadow-2xl"
      >
        <svg class="w-5 h-5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <rect x="3" y="4" width="18" height="18" rx="2" ry="2"/><line x1="16" y1="2" x2="16" y2="6"/><line x1="8" y1="2" x2="8" y2="6"/><line x1="3" y1="10" x2="21" y2="10"/>
        </svg>
        Agenda una llamada gratis
      </a>
      <a
        href="mailto:hola@bayonadigitalsystems.com"
        class="btn text-base py-4 px-8 border-2 border-white/30 bg-transparent text-white hover:bg-white/10 hover:border-white/60"
      >
        <svg class="w-5 h-5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <rect x="2" y="4" width="20" height="16" rx="2"/><path d="m22 7-8.97 5.7a1.94 1.94 0 0 1-2.06 0L2 7"/>
        </svg>
        Enviar un email
      </a>
    </div>

    <!-- Trust signals -->
    <div class="flex flex-wrap items-center justify-center gap-6 reveal delay-400">
      {[
        { icon: '✓', text: 'Respuesta en 24h' },
        { icon: '✓', text: 'Sin compromiso' },
        { icon: '✓', text: 'Propuesta personalizada' },
      ].map(item => (
        <div class="flex items-center gap-2 text-sm text-white/70">
          <span class="text-[var(--color-accent-light)] font-bold">{item.icon}</span>
          {item.text}
        </div>
      ))}
    </div>

  </div>
</section>
