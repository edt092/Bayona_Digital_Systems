---
---

<section id="contacto" class="section relative overflow-hidden bg-[#0A0A0A]" aria-label="Contacto">
  <!-- Subtle radial glow from center -->
  <div
    class="absolute inset-0 pointer-events-none"
    style="background: radial-gradient(ellipse 70% 55% at 50% 50%, rgba(100,100,100,0.06) 0%, transparent 70%);"
    aria-hidden="true"
  ></div>

  <!-- Top edge line -->
  <div class="absolute top-0 left-1/4 right-1/4 h-px" style="background: linear-gradient(to right, transparent, rgba(168,168,168,0.12), transparent);"></div>

  <!-- Orbital arc backdrop -->
  <div class="absolute inset-0 overflow-hidden pointer-events-none" aria-hidden="true">
    <svg class="absolute inset-0 w-full h-full" viewBox="0 0 1440 600" preserveAspectRatio="xMidYMid slice" fill="none">
      <ellipse
        cx="720" cy="300" rx="600" ry="240"
        stroke="rgba(168,168,168,0.04)" stroke-width="1"
        style="transform-box: view-box; transform-origin: 50% 50%; animation: arc-orbit-cw 60s linear infinite;"
      />
      <ellipse
        cx="720" cy="300" rx="400" ry="160"
        stroke="rgba(168,168,168,0.03)" stroke-width="0.7"
        style="transform-box: view-box; transform-origin: 50% 50%; animation: arc-orbit-ccw 45s linear infinite;"
      />
    </svg>
  </div>

  <div class="relative max-w-3xl mx-auto px-6 text-center">

    <!-- Badge -->
    <div class="section-badge justify-center mb-6 reveal">
      <span class="inline-flex items-center gap-2 text-[10px] font-bold px-3 py-1.5 rounded-full border border-[#252525] bg-[#161616] text-[#606060] uppercase tracking-[0.12em]">
        <span class="w-1.5 h-1.5 rounded-full bg-[#505050]" style="animation: pulse-dot 2s ease-in-out infinite;"></span>
        Comencemos
      </span>
    </div>

    <h2 class="neon-yellow text-4xl md:text-5xl lg:text-[3.5rem] font-bold leading-[1.06] mb-6 reveal delay-100 tracking-tight">
      ¿Listo para hacer crecer<br/>
      tu negocio?
    </h2>

    <p class="text-lg text-[#7A7A7A] leading-relaxed mb-10 max-w-xl mx-auto reveal delay-200">
      Agenda una llamada de 30 minutos sin costo. Analizamos tu situación actual y diseñamos juntos el plan de acción.
    </p>

    <!-- CTAs -->
    <div class="flex flex-col sm:flex-row gap-4 justify-center mb-12 reveal delay-300">
      <a
        href="#"
        data-booking-open
        class="btn btn-primary text-[15px] py-4 px-8"
      >
        <svg class="w-5 h-5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <rect x="3" y="4" width="18" height="18" rx="2" ry="2"/><line x1="16" y1="2" x2="16" y2="6"/><line x1="8" y1="2" x2="8" y2="6"/><line x1="3" y1="10" x2="21" y2="10"/>
        </svg>
        Agenda una llamada gratis
      </a>
      <a
        href="mailto:hola@bayonadigitalsystems.com"
        class="btn btn-outline text-[15px] py-4 px-8"
      >
        <svg class="w-5 h-5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <rect x="2" y="4" width="20" height="16" rx="2"/><path d="m22 7-8.97 5.7a1.94 1.94 0 0 1-2.06 0L2 7"/>
        </svg>
        Enviar un email
      </a>
    </div>

    <!-- Trust signals -->
    <div class="flex flex-wrap items-center justify-center gap-6 reveal delay-400">
      {[
        'Respuesta en 24h',
        'Sin compromiso',
        'Propuesta personalizada',
      ].map(text => (
        <div class="flex items-center gap-2 text-sm text-[#4A4A4A]">
          <svg class="w-3.5 h-3.5 text-[#505050]" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
            <polyline points="20 6 9 17 4 12"/>
          </svg>
          {text}
        </div>
      ))}
    </div>

  </div>
</section>

<style>
  .neon-yellow {
    color: #FFE135;
    text-shadow:
      0 0 8px  rgba(255, 220, 0, 0.9),
      0 0 20px rgba(255, 200, 0, 0.7),
      0 0 45px rgba(255, 180, 0, 0.5),
      0 0 80px rgba(255, 160, 0, 0.25);
  }
</style>
