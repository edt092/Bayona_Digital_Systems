---
import { featuredProjects } from '@/data/projects';
---

<section id="proyectos" class="section bg-[#080808]" aria-label="Proyectos destacados">
  <div class="max-w-7xl mx-auto px-6">

    <!-- Header -->
    <div class="flex flex-col sm:flex-row sm:items-end justify-between gap-6 mb-12 reveal">
      <div>
        <div class="section-badge mb-4">
          <span class="badge badge-primary">Proyectos</span>
        </div>
        <h2 class="text-3xl md:text-4xl font-bold">
          Casos de éxito
          <span class="gradient-text"> reales</span>
        </h2>
        <p class="text-[var(--color-muted)] mt-3 max-w-md text-[15px]">
          No hablo de teoría. Aquí están los proyectos que han generado resultados reales para clientes reales.
        </p>
      </div>
      <a href="#contacto" class="btn btn-outline flex-shrink-0 text-sm self-start sm:self-end">
        Ver todos
        <svg class="w-4 h-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <path d="M5 12h14M12 5l7 7-7 7"/>
        </svg>
      </a>
    </div>

    <!-- Projects grid -->
    <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-5">
      {featuredProjects.map((project, i) => (
        <article
          class={`card overflow-hidden group reveal delay-${(i + 1) * 100}`}
          aria-label={`Proyecto: ${project.title}`}
        >
          <!-- Image -->
          <div class="relative h-44 overflow-hidden bg-[#0F0F0F]">
            {project.image && (
              <img
                src={project.image}
                alt={`Imagen del proyecto ${project.title}`}
                class="absolute inset-0 w-full h-full object-cover opacity-90"
              />
            )}
            {!project.image && (
              <div class="absolute inset-0 flex items-center justify-center">
                <div class="w-12 h-12 rounded-xl bg-[#1E1E1E] border border-[#282828] flex items-center justify-center">
                  <span class="text-[#606060] font-bold text-lg font-display">
                    {project.title.split(' ').map((w: string) => w[0]).join('').slice(0, 2)}
                  </span>
                </div>
              </div>
            )}
            <!-- Hover overlay -->
            <div class="absolute inset-0 bg-[#080808]/70 opacity-0 group-hover:opacity-100 transition-opacity duration-300 flex items-center justify-center">
              <a
                href={`/proyectos/${project.slug}`}
                class="btn btn-primary text-sm py-2 px-4 translate-y-3 group-hover:translate-y-0 transition-transform duration-300"
              >
                Ver caso de estudio
              </a>
            </div>
          </div>

          <!-- Content -->
          <div class="p-6">
            <div class="flex flex-wrap gap-1.5 mb-3">
              {project.tags.slice(0, 2).map((tag: string) => (
                <span class="text-[10px] font-semibold px-2 py-0.5 rounded-full bg-[#1A1A1A] text-[#606060] border border-[#282828]">
                  {tag}
                </span>
              ))}
              <span class="text-[10px] font-medium px-2 py-0.5 rounded-full bg-[#1A1A1A] text-[#808080] border border-[#282828]">
                {project.industry}
              </span>
            </div>

            <h3 class="font-semibold text-[var(--color-ink)] text-[15px] mb-5">{project.title}</h3>

            <div class="flex items-center justify-between pt-4 border-t border-[var(--color-border)]">
              <div>
                <div class="text-xs text-[var(--color-muted)]">Resultado</div>
                <div class="font-semibold text-[#A0A0A0] text-sm font-display">{project.result}</div>
              </div>
              <a
                href={`/proyectos/${project.slug}`}
                class="flex items-center gap-1 text-xs font-semibold text-[#606060] hover:text-[#ECECEC] hover:gap-2 transition-all duration-200"
                aria-label={`Ver caso de estudio de ${project.title}`}
              >
                Ver caso
                <svg class="w-3.5 h-3.5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
                  <path d="M5 12h14M12 5l7 7-7 7"/>
                </svg>
              </a>
            </div>
          </div>
        </article>
      ))}
    </div>

  </div>
</section>
