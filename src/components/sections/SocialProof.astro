---
const clientLogos = [
  { name: 'La Brasa Grill',      logo: '/companies_logos/la_brasa_grill.png' },
  { name: 'Apex Consulting',     logo: '/companies_logos/apex_consulting.png' },
  { name: 'Orígen Artesanal',   logo: '/companies_logos/origen_artesanal.png' },
  { name: 'Sonrisa Perfecta',   logo: '/companies_logos/sonrisa_perfecta.png' },
  { name: 'Tech Solutions',     logo: '/companies_logos/tech_solutions.png' },
  { name: 'Verde Digital',      logo: '/companies_logos/verde_digital.png' },
  { name: 'KSPromocionales',    logo: '/companies_logos/kronosolopromocionales.png' },
];

const metrics = [
  { value: '48+',  label: 'Proyectos entregados' },
  { value: '97%',  label: 'Tasa de satisfacción' },
  { value: '$2M+', label: 'Ingresos generados' },
];
---

<section class="py-12 border-y border-[#1A1A1A] bg-[#0A0A0A]" aria-label="Clientes y resultados">
  <div class="max-w-7xl mx-auto px-6">

    <p class="text-center text-[10px] font-semibold text-[#3A3A3A] uppercase tracking-[0.2em] mb-8">
      Marcas que confían en nuestro trabajo
    </p>

    <!-- Scrolling logos -->
    <div class="relative overflow-hidden mb-10">
      <div class="flex items-center gap-10 animate-scroll" style="width: max-content;">
        {[...clientLogos, ...clientLogos].map((client) => (
          <div class="flex items-center gap-2.5 flex-shrink-0 cursor-default group">
            <img
              src={client.logo}
              alt={client.name}
              class="h-7 w-auto object-contain tech-logo"
            />
            <span class="text-sm font-medium whitespace-nowrap text-[#3A3A3A] group-hover:text-[#7A7A7A] transition-colors duration-200">{client.name}</span>
          </div>
        ))}
      </div>

      <!-- Fade edges -->
      <div class="absolute inset-y-0 left-0 w-20 pointer-events-none" style="background: linear-gradient(to right, #0A0A0A, transparent);"></div>
      <div class="absolute inset-y-0 right-0 w-20 pointer-events-none" style="background: linear-gradient(to left, #0A0A0A, transparent);"></div>
    </div>

    <!-- Metrics -->
    <div class="grid grid-cols-3 gap-6 max-w-sm mx-auto">
      {metrics.map(metric => (
        <div class="text-center">
          <div class="text-xl font-bold text-[#ECECEC] font-display">{metric.value}</div>
          <div class="text-[10px] text-[#4A4A4A] mt-0.5 tracking-wide">{metric.label}</div>
        </div>
      ))}
    </div>

  </div>
</section>

<style>
  @keyframes scroll {
    from { transform: translateX(0); }
    to   { transform: translateX(-50%); }
  }
  .animate-scroll { animation: scroll 28s linear infinite; }
  .animate-scroll:hover { animation-play-state: paused; }
</style>
