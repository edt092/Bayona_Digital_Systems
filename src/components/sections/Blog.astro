---
// Placeholder blog posts — will be replaced by Astro Content Collections
const posts = [
  {
    slug: 'seo-para-negocios-locales',
    title: 'SEO Local: Cómo aparecer en Google cuando buscan tu tipo de negocio',
    excerpt: 'Descubre las estrategias específicas de SEO local que han ayudado a mis clientes a dominar los resultados de búsqueda en su ciudad.',
    category: 'SEO',
    date: '2024-12-15',
    readTime: '8 min',
    featured: true,
  },
  {
    slug: 'velocidad-web-conversiones',
    title: 'Por qué cada segundo de carga cuesta el 7% de tus conversiones',
    excerpt: 'La relación directa entre velocidad de carga y ventas: datos reales de proyectos donde mejorar el rendimiento duplicó los ingresos.',
    category: 'Desarrollo Web',
    date: '2024-12-08',
    readTime: '6 min',
    featured: false,
  },
  {
    slug: 'google-ads-pymes',
    title: 'Google Ads para PYMEs: Cómo gastar $500 y obtener $5,000',
    excerpt: 'Una guía práctica basada en campañas reales: cómo estructurar y optimizar tus campañas para maximizar el ROI con presupuesto limitado.',
    category: 'Marketing Digital',
    date: '2024-12-01',
    readTime: '10 min',
    featured: false,
  },
];

const categoryColors: Record<string, string> = {
  'SEO': 'badge-accent',
  'Desarrollo Web': 'badge-primary',
  'Marketing Digital': 'bg-[rgb(37_99_235/0.08)] text-[var(--color-secondary)] border border-[rgb(37_99_235/0.15)]',
};
---

<section id="blog" class="section bg-[var(--color-surface)]" aria-label="Blog">
  <div class="max-w-7xl mx-auto px-6">

    <!-- Header -->
    <div class="flex flex-col sm:flex-row sm:items-end justify-between gap-6 mb-12 reveal">
      <div>
        <div class="section-badge mb-4">
          <span class="badge badge-primary">Blog</span>
        </div>
        <h2 class="text-3xl md:text-4xl font-black">
          Estrategias que
          <span class="gradient-text"> generan resultados</span>
        </h2>
        <p class="text-[var(--color-muted)] mt-3 max-w-md">
          Artículos prácticos basados en proyectos reales. Sin relleno, sin teoría hueca.
        </p>
      </div>
      <a href="/blog" class="btn btn-outline flex-shrink-0 text-sm self-start sm:self-end">
        Ver todos los artículos
        <svg class="w-4 h-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <path d="M5 12h14M12 5l7 7-7 7"/>
        </svg>
      </a>
    </div>

    <!-- Posts grid -->
    <div class="grid md:grid-cols-3 gap-6">
      {posts.map((post, i) => (
        <article
          class={`card overflow-hidden group reveal delay-${(i + 1) * 100}`}
          aria-label={`Artículo: ${post.title}`}
        >
          <!-- Image placeholder -->
          <div
            class="h-40 relative overflow-hidden"
            style={`background: ${i === 0
              ? 'linear-gradient(135deg, var(--color-accent-dark) 0%, var(--color-primary) 100%)'
              : i === 1
              ? 'linear-gradient(135deg, var(--color-primary) 0%, var(--color-secondary) 100%)'
              : 'linear-gradient(135deg, var(--color-secondary) 0%, var(--color-accent) 100%)'};`}
          >
            <div class="absolute inset-0 bg-grid opacity-15"></div>
            <div class="absolute bottom-4 left-4">
              <span class={`badge text-[10px] ${categoryColors[post.category] || 'badge-primary'}`}>
                {post.category}
              </span>
            </div>
          </div>

          <div class="p-6">
            <!-- Meta -->
            <div class="flex items-center gap-2 text-xs text-[var(--color-subtle)] mb-3">
              <time datetime={post.date}>
                {new Date(post.date).toLocaleDateString('es-ES', { day: 'numeric', month: 'short', year: 'numeric' })}
              </time>
              <span>·</span>
              <span>{post.readTime} lectura</span>
            </div>

            <h3 class="font-bold text-[var(--color-ink)] mb-3 leading-snug group-hover:text-[var(--color-secondary)] transition-colors duration-200">
              <a href={`/blog/${post.slug}`}>{post.title}</a>
            </h3>

            <p class="text-sm text-[var(--color-muted)] leading-relaxed mb-4 line-clamp-2">
              {post.excerpt}
            </p>

            <a
              href={`/blog/${post.slug}`}
              class="flex items-center gap-1.5 text-xs font-semibold text-[var(--color-secondary)] hover:gap-2.5 transition-all duration-200"
              aria-label={`Leer: ${post.title}`}
            >
              Leer artículo
              <svg class="w-3.5 h-3.5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
                <path d="M5 12h14M12 5l7 7-7 7"/>
              </svg>
            </a>
          </div>
        </article>
      ))}
    </div>

  </div>
</section>
