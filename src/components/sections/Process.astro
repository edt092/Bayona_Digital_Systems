---
import { processSteps } from '@/data/process';
---

<section id="proceso" class="section bg-[var(--color-surface)]" aria-label="Proceso de trabajo">
  <div class="max-w-7xl mx-auto px-6">

    <!-- Header -->
    <div class="text-center max-w-2xl mx-auto mb-16 reveal">
      <div class="section-badge justify-center mb-4">
        <span class="badge badge-accent">Proceso</span>
      </div>
      <h2 class="text-3xl md:text-4xl font-black mb-4">
        Cómo trabajamos juntos para
        <span class="gradient-text"> conseguir resultados</span>
      </h2>
      <p class="text-[var(--color-muted)] text-lg">
        Un proceso probado que elimina la incertidumbre y asegura que cada proyecto se entregue en tiempo y forma.
      </p>
    </div>

    <!-- Process timeline desktop -->
    <div class="hidden lg:block">
      <!-- Connector line -->
      <div class="relative mb-8">
        <div class="absolute top-8 left-[10%] right-[10%] h-px bg-gradient-to-r from-transparent via-[var(--color-border)] to-transparent"></div>

        <div class="grid grid-cols-5 gap-4">
          {processSteps.map((step, i) => (
            <div class="flex flex-col items-center text-center gap-4 reveal" style={`animation-delay: ${i * 120}ms`}>
              <!-- Step number circle -->
              <div class="relative">
                <div class="w-16 h-16 rounded-full bg-white border-2 border-[var(--color-border)] flex flex-col items-center justify-center shadow-sm hover:border-[var(--color-secondary)] hover:shadow-[var(--shadow-primary)] transition-all duration-300 group cursor-default">
                  <span class="text-[10px] font-bold text-[var(--color-secondary)] font-display group-hover:text-[var(--color-primary)] transition-colors">{step.number}</span>
                </div>
              </div>

              <!-- Content -->
              <div>
                <h3 class="font-bold text-[var(--color-ink)] text-sm mb-2">{step.title}</h3>
                <p class="text-xs text-[var(--color-muted)] leading-relaxed">{step.description}</p>
              </div>

              <!-- Deliverables -->
              <div class="flex flex-col gap-1.5 w-full">
                {step.deliverables.map(item => (
                  <div class="flex items-center gap-1.5 text-[10px] text-[var(--color-muted)]">
                    <svg class="w-3 h-3 flex-shrink-0 text-[var(--color-accent)]" viewBox="0 0 24 24" fill="currentColor">
                      <circle cx="12" cy="12" r="5"/>
                    </svg>
                    {item}
                  </div>
                ))}
              </div>
            </div>
          ))}
        </div>
      </div>
    </div>

    <!-- Process timeline mobile -->
    <div class="lg:hidden space-y-0">
      {processSteps.map((step, i) => (
        <div class="flex gap-5 reveal" style={`animation-delay: ${i * 100}ms`}>
          <!-- Left: number + connector -->
          <div class="flex flex-col items-center">
            <div class="w-10 h-10 rounded-full bg-white border-2 border-[var(--color-border)] flex items-center justify-center flex-shrink-0 shadow-sm">
              <span class="text-xs font-black text-[var(--color-secondary)] font-display">{step.number}</span>
            </div>
            {i < processSteps.length - 1 && (
              <div class="w-px flex-1 bg-[var(--color-border)] my-2" style="min-height: 40px;"></div>
            )}
          </div>

          <!-- Right: content -->
          <div class="pb-8 flex-1">
            <h3 class="font-bold text-[var(--color-ink)] mb-2">{step.title}</h3>
            <p class="text-sm text-[var(--color-muted)] leading-relaxed mb-3">{step.description}</p>
            <div class="flex flex-wrap gap-2">
              {step.deliverables.map(item => (
                <span class="text-xs bg-[var(--color-border-soft)] text-[var(--color-muted)] px-2.5 py-1 rounded-full border border-[var(--color-border)]">
                  {item}
                </span>
              ))}
            </div>
          </div>
        </div>
      ))}
    </div>

  </div>
</section>
