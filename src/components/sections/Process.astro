---
import { processSteps } from '@/data/process';
---

<section id="proceso" class="section bg-[#0F0F0F]" aria-label="Proceso de trabajo">
  <div class="max-w-7xl mx-auto px-6">

    <!-- Header -->
    <div class="text-center max-w-2xl mx-auto mb-16 reveal">
      <div class="section-badge justify-center mb-4">
        <span class="badge badge-accent">Proceso</span>
      </div>
      <h2 class="text-3xl md:text-4xl font-bold mb-4">
        Cómo trabajamos juntos para
        <span class="neon-yellow"> conseguir resultados</span>
      </h2>
      <p class="text-[var(--color-muted)] text-lg">
        Un proceso probado que elimina la incertidumbre y asegura que cada proyecto se entregue en tiempo y forma.
      </p>
    </div>

    <!-- Desktop timeline -->
    <div class="hidden lg:block">
      <div class="relative mb-8">
        <!-- Connector line -->
        <div class="absolute top-8 left-[10%] right-[10%] h-px bg-gradient-to-r from-transparent via-[#282828] to-transparent"></div>

        <div class="grid grid-cols-5 gap-4">
          {processSteps.map((step, i) => (
            <div class="process-step flex flex-col items-center text-center gap-4 reveal" style={`animation-delay: ${i * 120}ms`}>
              <div class="relative">
                <div class="w-16 h-16 rounded-full bg-[#161616] border border-[#282828] flex flex-col items-center justify-center shadow-sm transition-all duration-300 cursor-default">
                  <span class="step-number text-[10px] font-bold font-display transition-all duration-300">{step.number}</span>
                </div>
              </div>
              <div>
                <h3 class="step-title font-semibold text-sm mb-2 transition-all duration-300">{step.title}</h3>
                <p class="text-xs text-[var(--color-muted)] leading-relaxed">{step.description}</p>
              </div>
              <div class="flex flex-col gap-1.5 w-full">
                {step.deliverables.map((item: string) => (
                  <div class="flex items-center gap-1.5 text-[10px] text-[var(--color-muted)]">
                    <svg class="w-2.5 h-2.5 flex-shrink-0 text-[#505050]" viewBox="0 0 24 24" fill="currentColor">
                      <circle cx="12" cy="12" r="5"/>
                    </svg>
                    {item}
                  </div>
                ))}
              </div>
            </div>
          ))}
        </div>
      </div>
    </div>

    <!-- Mobile timeline -->
    <div class="lg:hidden space-y-0">
      {processSteps.map((step, i) => (
        <div class="process-step flex gap-5 reveal" style={`animation-delay: ${i * 100}ms`}>
          <div class="flex flex-col items-center">
            <div class="w-10 h-10 rounded-full bg-[#161616] border border-[#282828] flex items-center justify-center flex-shrink-0">
              <span class="step-number text-xs font-bold font-display transition-all duration-300">{step.number}</span>
            </div>
            {i < processSteps.length - 1 && (
              <div class="w-px flex-1 bg-[#1E1E1E] my-2" style="min-height: 40px;"></div>
            )}
          </div>
          <div class="pb-8 flex-1">
            <h3 class="step-title font-semibold mb-2 text-sm transition-all duration-300">{step.title}</h3>
            <p class="text-sm text-[var(--color-muted)] leading-relaxed mb-3">{step.description}</p>
            <div class="flex flex-wrap gap-2">
              {step.deliverables.map((item: string) => (
                <span class="text-xs bg-[#161616] text-[#606060] px-2.5 py-1 rounded-full border border-[#252525]">
                  {item}
                </span>
              ))}
            </div>
          </div>
        </div>
      ))}
    </div>

  </div>
</section>

<style>
  .neon-yellow {
    color: #FFE135;
    text-shadow:
      0 0 8px  rgba(255, 220, 0, 0.9),
      0 0 20px rgba(255, 200, 0, 0.7),
      0 0 45px rgba(255, 180, 0, 0.5),
      0 0 80px rgba(255, 160, 0, 0.25);
  }

  .step-number {
    color: #808080;
  }
  .step-title {
    color: var(--color-ink);
  }

  .process-step:hover .step-number,
  .process-step:hover .step-title {
    color: #FFE135;
    text-shadow:
      0 0 6px  rgba(255, 225, 0, 0.95),
      0 0 18px rgba(255, 200, 0, 0.75),
      0 0 40px rgba(255, 175, 0, 0.45),
      0 0 70px rgba(255, 150, 0, 0.20);
  }

  .process-step:hover .step-number {
    font-size: 0.75rem;
  }
</style>
