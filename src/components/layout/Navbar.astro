---
const navLinks = [
  { label: 'Servicios',  href: '#servicios' },
  { label: 'Proyectos',  href: '#proyectos' },
  { label: 'Proceso',    href: '#proceso' },
  { label: 'Sobre mí',  href: '#sobre-mi' },
  { label: 'Contacto',  href: '#contacto' },
];
---

<header id="navbar" class="fixed top-0 left-0 right-0 z-50 transition-all duration-300">
  <nav class="max-w-7xl mx-auto px-6 h-16 flex items-center justify-between">

    <!-- Logo -->
    <a href="/" class="flex items-center gap-3.5 group" aria-label="Bayona Digital Systems — Inicio">

      <!-- Logo image -->
      <img
        src="/logo-eb.png"
        alt="Bayona Digital Systems"
        width="72"
        height="72"
        class="flex-shrink-0 transition-opacity duration-200 group-hover:opacity-80"
        loading="eager"
      />

      <!-- Wordmark -->
      <div class="hidden sm:flex flex-col leading-none">
        <span class="font-display font-semibold text-[13px] tracking-[0.18em] text-white uppercase">
          Bayona Digital
        </span>
        <span class="font-body text-[10px] tracking-[0.2em] text-[#555] uppercase mt-0.5">
          Systems
        </span>
      </div>
    </a>

    <!-- Desktop nav -->
    <div class="hidden md:flex items-center gap-7">
      {navLinks.map(link => (
        <a href={link.href} class="nav-link">{link.label}</a>
      ))}
    </div>

    <!-- CTA + mobile toggle -->
    <div class="flex items-center gap-3">
      <a
        href="#"
        data-booking-open
        class="hidden sm:inline-flex btn btn-primary text-sm py-2 px-4"
      >
        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07A19.5 19.5 0 0 1 4.99 12 19.79 19.79 0 0 1 1.9 3.41 2 2 0 0 1 3.88 1h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L8.09 8.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 22 16.92z"/>
        </svg>
        Agenda una llamada
      </a>

      <button
        id="menu-toggle"
        class="md:hidden p-2 rounded-lg text-[#555] hover:text-[#ECECEC] hover:bg-[#1A1A1A] transition-colors"
        aria-label="Abrir menú"
        aria-expanded="false"
      >
        <svg id="icon-menu" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <line x1="3" y1="6" x2="21" y2="6"/><line x1="3" y1="12" x2="21" y2="12"/><line x1="3" y1="18" x2="21" y2="18"/>
        </svg>
        <svg id="icon-close" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="hidden">
          <line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/>
        </svg>
      </button>
    </div>
  </nav>

  <!-- Mobile menu -->
  <div
    id="mobile-menu"
    class="md:hidden hidden border-t border-[#1E1E1E] bg-[#0A0A0A]/98 backdrop-blur-xl"
  >
    <div class="max-w-7xl mx-auto px-6 py-4 flex flex-col gap-1">
      {navLinks.map(link => (
        <a
          href={link.href}
          class="py-2.5 px-3 rounded-lg text-sm font-medium text-[#7A7A7A] hover:text-[#ECECEC] hover:bg-[#161616] transition-colors"
        >
          {link.label}
        </a>
      ))}
      <div class="pt-3 border-t border-[#1E1E1E] mt-2">
        <a href="#" data-booking-open class="btn btn-primary w-full justify-center text-sm">
          Agenda una llamada
        </a>
      </div>
    </div>
  </div>
</header>

<style>
  #navbar {
    background: transparent;
  }
  #navbar.scrolled {
    background: rgba(8, 8, 8, 0.92);
    backdrop-filter: blur(20px);
    -webkit-backdrop-filter: blur(20px);
    border-bottom: 1px solid rgba(255, 255, 255, 0.05);
  }
</style>

<script>
  /* ── Navbar scroll / mobile menu ── */
  const navbar    = document.getElementById('navbar');
  const toggle    = document.getElementById('menu-toggle');
  const menu      = document.getElementById('mobile-menu');
  const iconMenu  = document.getElementById('icon-menu');
  const iconClose = document.getElementById('icon-close');

  window.addEventListener('scroll', () => {
    navbar?.classList.toggle('scrolled', window.scrollY > 20);
  }, { passive: true });

  toggle?.addEventListener('click', () => {
    const isOpen = !menu?.classList.contains('hidden');
    menu?.classList.toggle('hidden');
    iconMenu?.classList.toggle('hidden', !isOpen);
    iconClose?.classList.toggle('hidden', isOpen);
    toggle.setAttribute('aria-expanded', String(!isOpen));
  });

  menu?.querySelectorAll('a').forEach(link => {
    link.addEventListener('click', () => {
      menu.classList.add('hidden');
      iconMenu?.classList.remove('hidden');
      iconClose?.classList.add('hidden');
      toggle?.setAttribute('aria-expanded', 'false');
    });
  });

</script>
